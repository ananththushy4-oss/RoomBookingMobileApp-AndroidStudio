<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true"
    tools:context=".screens.HomeScreen">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <FrameLayout
            android:id="@+id/hero_banner"
            android:layout_width="0dp"
            android:layout_height="220dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_eco"
                android:contentDescription="Hero banner"
                app:tint="@color/colorPrimaryVariant" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#99000000" />

            <TextView
                android:id="@+id/tv_welcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="24dp"
                android:text="@string/welcome_to_ecostay_retreat"
                android:textColor="@android:color/white"
                android:textSize="28sp"
                android:textStyle="bold" />
        </FrameLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/search_bar_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="24dp"
            android:hint="@string/search_hint"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxStrokeColor="@color/colorPrimary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/hero_banner"
            app:startIconDrawable="@drawable/ic_explore">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionSearch"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_book_room"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/book_a_room"
            android:textColor="@color/colorPrimary"
            app:cornerRadius="16dp"
            app:strokeColor="@color/colorPrimary"
            app:layout_constraintEnd_toStartOf="@+id/btn_reserve_activity"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toStartOf="@+id/search_bar_layout"
            app:layout_constraintTop_toBottomOf="@id/search_bar_layout" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reserve_activity"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:text="@string/reserve_activity"
            android:textColor="@color/colorPrimary"
            app:cornerRadius="16dp"
            app:strokeColor="@color/colorPrimary"
            app:layout_constraintEnd_toStartOf="@+id/btn_view_bookings"
            app:layout_constraintStart_toEndOf="@+id/btn_book_room"
            app:layout_constraintTop_toTopOf="@+id/btn_book_room" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_view_bookings"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/view_bookings"
            android:textColor="@color/colorPrimary"
            app:cornerRadius="16dp"
            app:strokeColor="@color/colorPrimary"
            app:layout_constraintEnd_toEndOf="@+id/search_bar_layout"
            app:layout_constraintStart_toEndOf="@+id/btn_reserve_activity"
            app:layout_constraintTop_toTopOf="@+id/btn_book_room" />


        <TextView
            android:id="@+id/tv_top_rooms_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="@string/top_rated_rooms"
            android:textColor="@color/colorOnSurface"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_book_room" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_top_rooms"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_top_rooms_title"
            tools:listitem="@layout/item_carousel_card" />

        <TextView
            android:id="@+id/tv_eco_activities_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="@string/eco_friendly_activities"
            android:textColor="@color/colorOnSurface"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rv_top_rooms" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_eco_activities"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_eco_activities_title"
            tools:listitem="@layout/item_carousel_card" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>